<?xml version="1.0"?>
<robot name="mycar">
    <link name="footprint">
        <visual>
            <geometry>
                <box size="0.001 0.001 0.001"/>
            </geometry>
        </visual>
    </link>
    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.3 0.2 0.1"/>
            </geometry>
            <material name="mycar">
                <color rgba="0 0 1 1" />
            </material>
        </visual>    
    </link> 
    <link name="camrea">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.05"/>
            </geometry>
            <material name="camera">
                <color rgba="0 0 0 1" />
            </material>
            <origin xyz="0.0 0.0 0.025" rpy="0.0 0.0 0.0"/>
            
        </visual>
    </link>
    <joint name="camareq" type="continuous">
        <!-- 父级 link -->
        <parent link="base_link"/>
        
        <!-- ziji link -->
        <child link="camrea"/>

        <!-- pian yi -->
        <origin xyz="0.15 0 0.052" rpy="0.0 0.0 0.0"/>
                
        <!-- guanjie -->
        <axis xyz="0.0 0.0 1"/>

    </joint>
    <joint name="footprint" type="fixed">
        <parent link="footprint"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
        
                
    </joint>    
</robot>